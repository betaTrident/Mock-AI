# MockAI environment variables
# Copy to `.env.local` and fill in real values. Never commit `.env` or `.env.local`.

# -----------------------------------------------------------------------------
# SERVER_ONLY — never expose via NEXT_PUBLIC_ or client bundles
# -----------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GEMINI_API_KEY=your_gemini_api_key_here

# Upstash Redis — rate limiting (middleware)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Sentry — error tracking (optional in development)
SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000
SENTRY_ORG=your-org
SENTRY_PROJECT=mock-ai
# SENTRY_AUTH_TOKEN=  # CI only — enables source map upload

# -----------------------------------------------------------------------------
# PUBLIC — Firebase client SDK (safe to expose when Firestore rules are strict)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# -----------------------------------------------------------------------------
# LEGACY — Vite-era variables (see /legacy, do not use in Next.js app)
# -----------------------------------------------------------------------------
# VITE_GEMINI_API_KEY=  # ROTATED — use GEMINI_API_KEY server-side instead

# -----------------------------------------------------------------------------
# POST-MIGRATION — developer action required
# -----------------------------------------------------------------------------
# Rotate GEMINI_API_KEY and FIREBASE_SERVICE_ACCOUNT_KEY after migration.
# The legacy VITE_GEMINI_API_KEY was client-exposed and must be considered compromised.
